<%- include('../components/header', { title: req.translations.userAccountTitle || 'Account' }) %>

<style>
  ::-webkit-scrollbar { display: none; }
  body, html { height: 100%; margin: 0; }

  .profile-grid {
    display: grid;
    grid-template-cols: 1fr;
    gap: 20px;
  }
  @media (min-width: 768px) {
    .profile-grid {
      grid-template-cols: 120px 1fr;
    }
  }
</style>

<main class="h-screen m-auto">
  <div class="flex h-screen">
    <div class="w-60 h-full">
      <%- include('../components/template') %>
    </div>
    <div id="page-content" class="flex-1 overflow-y-auto pt-16 pb-12">

      <div class="px-8 pt-5 mb-5">
        <div class="flex items-center gap-4">
          <!-- Avatar -->
          <div class="relative shrink-0">
            <img id="avatar-preview"
              src="<%= user.avatar ? user.avatar : 'https://api.dicebear.com/9.x/thumbs/svg?seed=' + encodeURIComponent(user.username) %>"
              alt="Avatar"
              class="h-12 w-12 rounded-xl border border-neutral-200 dark:border-white/10 object-cover">
          </div>
          <!-- Title -->
          <div class="min-w-0 flex-1">
            <h1 class="text-base font-medium text-neutral-800 dark:text-white"><%= req.translations.userAccountTitle || 'Account' %></h1>
            <p class="text-sm text-neutral-500 mt-0.5"><%= req.translations.userAccountText || 'View your profile and manage preferences.' %></p>
          </div>
          <!-- Credits button -->
          <a href="/credits"
            class="flex items-center gap-1.5 rounded-xl border border-neutral-200 dark:border-white/5 bg-white dark:bg-white/5 hover:bg-neutral-50 dark:hover:bg-white/10 text-neutral-600 dark:text-neutral-400 hover:text-neutral-800 dark:hover:text-white px-3 py-1.5 text-xs font-medium shadow-sm dark:shadow-none transition shrink-0">
            <%- icon('circle-alert', { class: 'w-3.5 h-3.5' }) %>
            Credits
          </a>
        </div>
      </div>

      <div class="px-8 space-y-4">

        <!-- Unified settings card -->
        <div class="bg-neutral-50 dark:bg-white/5 rounded-2xl border border-neutral-200 dark:border-white/5 p-5">
          <div class="space-y-6">

            <!-- Discord profile details (Read-only) -->
            <div>
              <h2 class="text-xs font-semibold text-neutral-400 dark:text-neutral-500 uppercase tracking-wider mb-3">Discord Identity</h2>
              <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
                <div>
                  <label class="block text-xs font-medium text-neutral-500 dark:text-neutral-400 mb-1">Discord Username</label>
                  <input type="text" value="<%= user.discord_username || 'N/A' %>" readonly
                    class="rounded-lg border border-neutral-200 dark:border-neutral-600/30 text-xs w-full bg-neutral-100 dark:bg-neutral-800/40 px-3 py-2 text-neutral-500 dark:text-neutral-400 cursor-not-allowed outline-none">
                </div>
                <div>
                  <label class="block text-xs font-medium text-neutral-500 dark:text-neutral-400 mb-1">Display Name</label>
                  <input type="text" value="<%= user.discord_display_name || 'N/A' %>" readonly
                    class="rounded-lg border border-neutral-200 dark:border-neutral-600/30 text-xs w-full bg-neutral-100 dark:bg-neutral-800/40 px-3 py-2 text-neutral-500 dark:text-neutral-400 cursor-not-allowed outline-none">
                </div>
                <div>
                  <label class="block text-xs font-medium text-neutral-500 dark:text-neutral-400 mb-1">Discord Email</label>
                  <input type="text" value="<%= user.discord_email || 'N/A' %>" readonly
                    class="rounded-lg border border-neutral-200 dark:border-neutral-600/30 text-xs w-full bg-neutral-100 dark:bg-neutral-800/40 px-3 py-2 text-neutral-500 dark:text-neutral-400 cursor-not-allowed outline-none">
                </div>
              </div>
            </div>

            <div class="border-t border-neutral-200 dark:border-white/5 my-4"></div>

            <div class="grid grid-cols-2 gap-x-5 gap-y-4">
              <!-- Description -->
              <form id="change-description-form" class="col-span-2">
                <%- include('../components/csrf') %>
                <label class="flex items-center gap-1.5 text-xs font-medium text-neutral-500 dark:text-neutral-400 mb-1"><%- icon('file-text', { class: 'w-3 h-3' }) %> <%= req.translations.description || 'Description' %></label>
                <textarea id="description" name="description" rows="2"
                  class="rounded-lg border border-neutral-200 dark:border-neutral-600/30 focus:border-neutral-400 dark:focus:border-white/50 focus:ring-1 focus:ring-neutral-300 dark:focus:ring-white/30 focus:outline-none text-xs w-full bg-white dark:bg-neutral-700/20 px-3 py-1.5 text-neutral-800 dark:text-white placeholder-neutral-400 transition-colors resize-none"
                  placeholder="<%= user.description %>"><%= user.description %></textarea>
                <button type="submit" class="mt-1.5 rounded-lg bg-neutral-900 dark:bg-white text-white dark:text-neutral-900 px-2.5 py-1.5 text-xs font-medium transition">
                  Save
                </button>
              </form>

              <!-- Language -->
              <form id="language-preference-form" class="col-span-1">
                <%- include('../components/csrf') %>
                <label class="flex items-center gap-1.5 text-xs font-medium text-neutral-500 dark:text-neutral-400 mb-1"><%- icon('globe', { class: 'w-3 h-3' }) %> <%= req.translations.languagePreference || 'Language' %></label>
                <select id="language" name="language"
                  class="rounded-lg border border-neutral-200 dark:border-neutral-600/30 focus:border-neutral-400 dark:focus:border-white/50 focus-visible:ring-2 focus-visible:ring-neutral-400 focus-visible:ring-offset-1 outline-none text-xs w-full bg-white dark:bg-neutral-700/20 px-3 py-1.5 text-neutral-800 dark:text-white transition-colors mb-1.5">
                  <option value="en"  <%= req.lang === 'en'  ? 'selected' : '' %>>English</option>
                  <option value="fr"  <%= req.lang === 'fr'  ? 'selected' : '' %>>Français</option>
                  <option value="de"  <%= req.lang === 'de'  ? 'selected' : '' %>>Deutsch</option>
                  <option value="es"  <%= req.lang === 'es'  ? 'selected' : '' %>>Español</option>
                  <option value="pt"  <%= req.lang === 'pt'  ? 'selected' : '' %>>Português</option>
                  <option value="it"  <%= req.lang === 'it'  ? 'selected' : '' %>>Italiano</option>
                  <option value="ru"  <%= req.lang === 'ru'  ? 'selected' : '' %>>Русский</option>
                  <option value="zh"  <%= req.lang === 'zh'  ? 'selected' : '' %>>中文</option>
                  <option value="ja"  <%= req.lang === 'ja'  ? 'selected' : '' %>>日本語</option>
                  <option value="ta"  <%= req.lang === 'ta'  ? 'selected' : '' %>>தமிழ்</option>
                </select>
                <button type="submit"
                  class="rounded-lg bg-neutral-900 dark:bg-white text-white dark:text-neutral-900 px-2.5 py-1.5 text-xs font-medium shrink-0 transition">
                  Save
                </button>
              </form>

              <!-- 2FA (Legacy Placeholder) -->
              <div class="col-span-1">
                <p class="flex items-center gap-1.5 text-xs font-medium text-neutral-500 dark:text-neutral-400 mb-1"><%- icon('shield', { class: 'w-3 h-3' }) %> <%= req.translations.twoFactorAuth || 'Two-factor authentication' %></p>
                <p class="text-xs text-neutral-500 dark:text-neutral-400 mt-2">Managed securely via Discord Authentication.</p>
              </div>
            </div>

          </div>
        </div>

        <!-- Login history -->
        <div class="bg-neutral-50 dark:bg-white/5 rounded-2xl p-5 border border-neutral-200 dark:border-white/5">
          <p class="text-sm font-medium text-neutral-800 dark:text-white mb-4"><%= req.translations.loginHistory || 'Login history' %></p>
          <div class="overflow-x-auto rounded-xl border border-neutral-200 dark:border-white/5">
            <table class="min-w-full text-sm divide-y divide-neutral-200 dark:divide-white/5">
              <thead class="bg-neutral-100 dark:bg-white/5">
                <tr>
                  <th class="px-4 py-3 text-left text-xs font-medium text-neutral-500 dark:text-neutral-400"><%= req.translations.dateTime || 'Date & Time' %></th>
                  <th class="px-4 py-3 text-left text-xs font-medium text-neutral-500 dark:text-neutral-400"><%= req.translations.ipAddress || 'IP Address' %></th>
                  <th class="px-4 py-3 text-left text-xs font-medium text-neutral-500 dark:text-neutral-400"><%= req.translations.browserDevice || 'Browser / Device' %></th>
                </tr>
              </thead>
              <tbody class="divide-y divide-neutral-100 dark:divide-white/5">
                <% if (loginHistory && loginHistory.length > 0) { %>
                  <% let loginIdx = 0; loginHistory.forEach(login => { %>
                  <tr style="--i:<%= loginIdx++ %>" class="hover:bg-neutral-100 dark:hover:bg-white/5 transition-colors">
                    <td class="px-4 py-3 text-neutral-700 dark:text-neutral-300 whitespace-nowrap"><%= new Date(login.timestamp).toLocaleString() %></td>
                    <td class="px-4 py-3 text-neutral-500 dark:text-neutral-400 whitespace-nowrap font-mono text-xs"><%= login.ipAddress || 'Unknown' %></td>
                    <td class="px-4 py-3 text-neutral-400 text-xs truncate max-w-[260px]"><%= login.userAgent || 'Unknown' %></td>
                  </tr>
                  <% }) %>
                <% } else { %>
                <tr><td colspan="3" class="px-4 py-6 text-center text-sm text-neutral-400"><%= req.translations.noLoginHistory || 'No login history available' %></td></tr>
                <% } %>
              </tbody>
            </table>
          </div>
        </div>

      </div>
    </div>
  </div>
</main>

<%- include('../components/toast') %>

<script nonce="<%- nonce %>">
document.addEventListener('DOMContentLoaded', () => {
  const { showToast } = createToastSystem();
  const csrfToken = document.querySelector('meta[name="csrf-token"]')?.getAttribute('content');
  let submitting = false;

  async function post(url, data) {
    if (submitting) return;
    submitting = true;
    try {
      const res = await fetch(url, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', 'CSRF-Token': csrfToken },
        body: JSON.stringify(data),
      });
      const text = await res.text();
      if (res.ok) return { ok: true, text };
      return { ok: false, text };
    } finally {
      submitting = false;
    }
  }

  document.getElementById('change-description-form')?.addEventListener('submit', async e => {
    e.preventDefault();
    const el = e.target.querySelector('#description');
    const { ok, text } = await post('/update-description', { description: el.value.trim() });
    if (ok) { showToast('Description updated.', 'success'); el.placeholder = el.value.trim(); } else showToast(text);
  });

  document.getElementById('language-preference-form')?.addEventListener('submit', async e => {
    e.preventDefault();
    const lang = e.target.querySelector('#language').value;
    const res = await fetch('/set-language', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json', 'CSRF-Token': csrfToken },
      body: JSON.stringify({ language: lang }),
    });
    if (res.ok) { showToast('Language saved.', 'success'); setTimeout(() => location.reload(), 1400); }
    else showToast('Something went wrong.', 'error');
  });
});
</script>

<%- include('../components/footer') %>
