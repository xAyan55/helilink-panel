<%- include('../../components/header', { title: req.translations.adminEditUserTitle || 'Edit User' }) %>

<main id="page-content" class="">
  <%- include('../../components/template') %>

  <div class="px-4 py-5">
    <div class="mb-5">
      <a href="/admin/users" class="inline-flex items-center gap-1.5 text-xs text-neutral-500 dark:text-neutral-400 mb-3 hover:text-neutral-700 dark:hover:text-neutral-200 transition">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-3.5 h-3.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5 3 12m0 0 7.5-7.5M3 12h18" />
        </svg>
        <%= req.translations.back || 'Back to Users' %>
      </a>
      <h1 class="text-base font-medium text-neutral-800 dark:text-white"><%= req.translations.adminEditUserTitle || 'Edit User' %></h1>
      <p class="text-xs text-neutral-500 mt-0.5"><%= req.translations.adminEditUserText || 'Edit user details and permissions.' %></p>
    </div>

    <div id="userForm" class="mt-4 w-full">
      <div class="rounded-xl bg-neutral-50 dark:bg-neutral-800/20 border border-neutral-200 dark:border-white/5 p-5">
        <div class="flex items-center gap-3 mb-4 pb-4 border-b border-neutral-200 dark:border-white/5">
          <img class="h-11 w-11 rounded-xl object-cover shrink-0 border border-neutral-200 dark:border-neutral-700/30" src="<%= dataUser.avatar ? dataUser.avatar : 'https://api.dicebear.com/9.x/thumbs/svg?seed=' + encodeURIComponent(dataUser.username) %>" alt="">
          <div>
            <p class="text-sm font-semibold text-neutral-800 dark:text-white"><%= dataUser.username %></p>
            <p class="text-xs text-neutral-500 dark:text-neutral-400"><%= dataUser.discord_id || 'No Discord ID linked' %></p>
          </div>
        </div>
        <form id="editUserForm">
          <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <!-- User Information Section -->
            <div class="space-y-6">
              <h2 class="text-lg font-medium text-white border-b border-white/10 pb-2">
                <%= req.translations.userInformation || 'User Information' %>
              </h2>

              <!-- Username -->
              <div>
                <label for="username" class="block text-white text-sm font-medium mb-2">
                  <%= req.translations.username || 'Username' %>
                </label>
                <input
                  type="text"
                  id="username"
                  name="username"
                  value="<%= dataUser.username %>"
                  class="rounded-xl focus:ring focus:ring-neutral-800/10 focus:border-neutral-800/20 text-neutral-800 dark:text-white text-sm mt-2 mb-4 w-full hover:bg-white/5 px-4 py-2 bg-neutral-400/10 dark:bg-neutral-600/20 placeholder:text-neutral-950/50 dark:placeholder:text-white/20 border border-neutral-800/10 dark:border-white/5"
                  required
                >
              </div>

              <!-- Discord ID -->
              <div>
                <label for="discordId" class="block text-white text-sm font-medium mb-2">
                  Discord ID
                </label>
                <input
                  type="text"
                  id="discordId"
                  name="discordId"
                  value="<%= dataUser.discord_id || '' %>"
                  class="rounded-xl focus:ring focus:ring-neutral-800/10 focus:border-neutral-800/20 text-neutral-800 dark:text-white text-sm mt-2 mb-4 w-full hover:bg-white/5 px-4 py-2 bg-neutral-400/10 dark:bg-neutral-600/20 border border-neutral-800/10 dark:border-white/5"
                  required
                >
              </div>

              <!-- Description -->
              <div>
                <label for="description" class="block text-white text-sm font-medium mb-2">
                  <%= req.translations.description || 'Description' %>
                </label>
                <textarea
                  id="description"
                  name="description"
                  rows="3"
                  class="rounded-xl focus:ring focus:ring-neutral-800/10 focus:border-neutral-800/20 text-neutral-800 dark:text-white text-sm mt-2 mb-4 w-full hover:bg-white/5 px-4 py-2 bg-neutral-400/10 dark:bg-neutral-600/20 placeholder:text-neutral-950/50 dark:placeholder:text-white/20 border border-neutral-800/10 dark:border-white/5"
                ><%= dataUser.description || '' %></textarea>
              </div>
            </div>

            <!-- Discord Sync Status Section -->
            <div class="space-y-6">
              <h2 class="text-lg font-medium text-white border-b border-white/10 pb-2">
                Discord Sync Status
              </h2>
              <div>
                <label class="block text-neutral-500 dark:text-neutral-400 text-xs font-medium mb-1">Synced Username</label>
                <input type="text" value="<%= dataUser.discord_username || 'Not Synced' %>" readonly
                  class="rounded-xl text-neutral-500 bg-neutral-100 dark:bg-neutral-800/40 text-sm w-full px-4 py-2 border border-neutral-200 dark:border-neutral-600/30 cursor-not-allowed outline-none">
              </div>
              <div>
                <label class="block text-neutral-500 dark:text-neutral-400 text-xs font-medium mb-1">Synced Display Name</label>
                <input type="text" value="<%= dataUser.discord_display_name || 'Not Synced' %>" readonly
                  class="rounded-xl text-neutral-500 bg-neutral-100 dark:bg-neutral-800/40 text-sm w-full px-4 py-2 border border-neutral-200 dark:border-neutral-600/30 cursor-not-allowed outline-none">
              </div>
              <div>
                <label class="block text-neutral-500 dark:text-neutral-400 text-xs font-medium mb-1">Synced Email</label>
                <input type="text" value="<%= dataUser.discord_email || 'Not Synced' %>" readonly
                  class="rounded-xl text-neutral-500 bg-neutral-100 dark:bg-neutral-800/40 text-sm w-full px-4 py-2 border border-neutral-200 dark:border-neutral-600/30 cursor-not-allowed outline-none">
              </div>

              <!-- Admin Status -->
              <div class="mt-6">
                <div class="flex items-center">
                  <div class="bg-neutral-400/10 dark:bg-neutral-600/20 p-4 rounded-xl border border-neutral-800/10 dark:border-white/5 w-full">
                    <div class="flex items-center justify-between">
                      <div>
                        <h3 class="text-sm font-medium text-white">
                          <%= req.translations.adminStatus || 'Administrator Status' %>
                        </h3>
                        <p class="text-xs text-neutral-400 mt-1">
                          <%= req.translations.adminDescription || 'Administrators have full access to manage all aspects of the system.' %>
                        </p>
                      </div>
                      <label for="isAdmin" class="relative inline-block w-12 h-6">
                        <input type="checkbox" id="isAdmin" name="isAdmin" class="sr-only peer" <%= dataUser.isAdmin ? 'checked' : '' %>>
                        <span class="block w-12 h-6 bg-neutral-400 peer-checked:bg-blue-500 rounded-full"></span>
                        <span class="absolute left-0.5 top-0.5 w-5 h-5 bg-white rounded-full peer-checked:translate-x-6 transition"></span>
                      </label>
                      <span class="ms-3 text-sm font-medium text-white" id="adminStatusLabel"><%= dataUser.isAdmin ? req.translations.enabled || 'Enabled' : req.translations.disabled || 'Disabled' %></span>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </div>

          <!-- Server limits -->
          <div class="mt-5 pt-5 border-t border-neutral-200 dark:border-white/10">
            <p class="text-sm font-medium text-neutral-800 dark:text-white mb-1">Server limits</p>
            <p class="text-xs text-neutral-500 mb-3">Leave blank to use the global default from Admin &rarr; Settings.</p>
            <div class="space-y-3">
              <div>
                <label class="block text-xs font-medium text-neutral-600 dark:text-neutral-400 mb-1.5">Server limit</label>
                <input type="number" id="serverLimit" name="serverLimit" min="0" max="100"
                  value="<%= dataUser.serverLimit !== null && dataUser.serverLimit !== undefined ? dataUser.serverLimit : '' %>"
                  placeholder="Use global default"
                  class="w-full rounded-xl bg-neutral-100 dark:bg-neutral-800 border border-neutral-200 dark:border-neutral-700/40 px-3 py-2.5 text-sm text-neutral-800 dark:text-white placeholder-neutral-400 focus:outline-none transition">
                <p class="mt-1 text-[11px] text-neutral-400">0 = cannot create servers.</p>
              </div>
              <div>
                <label class="block text-xs font-medium text-neutral-600 dark:text-neutral-400 mb-1.5">Max memory (MB)</label>
                <input type="number" id="maxMemory" name="maxMemory" min="128" max="65536"
                  value="<%= dataUser.maxMemory !== null && dataUser.maxMemory !== undefined ? dataUser.maxMemory : '' %>"
                  placeholder="Use global default"
                  class="w-full rounded-xl bg-neutral-100 dark:bg-neutral-800 border border-neutral-200 dark:border-neutral-700/40 px-3 py-2.5 text-sm text-neutral-800 dark:text-white placeholder-neutral-400 focus:outline-none transition">
              </div>
              <div>
                <label class="block text-xs font-medium text-neutral-600 dark:text-neutral-400 mb-1.5">Max CPU (%)</label>
                <input type="number" id="maxCpu" name="maxCpu" min="10" max="10000"
                  value="<%= dataUser.maxCpu !== null && dataUser.maxCpu !== undefined ? dataUser.maxCpu : '' %>"
                  placeholder="Use global default"
                  class="w-full rounded-xl bg-neutral-100 dark:bg-neutral-800 border border-neutral-200 dark:border-neutral-700/40 px-3 py-2.5 text-sm text-neutral-800 dark:text-white placeholder-neutral-400 focus:outline-none transition">
              </div>
              <div>
                <label class="block text-xs font-medium text-neutral-600 dark:text-neutral-400 mb-1.5">Max storage (GB)</label>
                <input type="number" id="maxStorage" name="maxStorage" min="1" max="10000"
                  value="<%= dataUser.maxStorage !== null && dataUser.maxStorage !== undefined ? dataUser.maxStorage : '' %>"
                  placeholder="Use global default"
                  class="w-full rounded-xl bg-neutral-100 dark:bg-neutral-800 border border-neutral-200 dark:border-neutral-700/40 px-3 py-2.5 text-sm text-neutral-800 dark:text-white placeholder-neutral-400 focus:outline-none transition">
              </div>
            </div>
          </div>

          <!-- Submit Button -->
          <div class="mt-8 flex justify-end">
            <button
              type="submit"
              class="md:w-auto rounded-xl bg-neutral-950 dark:bg-white hover:bg-neutral-300 text-neutral-200 dark:text-neutral-800 px-6 py-2 text-sm font-medium shadow-md transition focus:outline focus:outline-2 focus:outline-offset-2"
            >
              <%= req.translations.saveChanges || 'Save Changes' %>
            </button>
          </div>
        </form>
      </div>
    </div>
  </div>
</main>

<%- include('../../components/toast') %>
<%- include('../../components/loadingPopup') %>

<script nonce="<%- nonce %>">
  document.addEventListener('DOMContentLoaded', function() {
    const form = document.getElementById('editUserForm');
    const isAdminToggle = document.getElementById('isAdmin');
    const adminStatusLabel = document.getElementById('adminStatusLabel');

    if (isAdminToggle) {
      isAdminToggle.addEventListener('change', function() {
        adminStatusLabel.textContent = this.checked
          ? '<%= req.translations.enabled || "Enabled" %>'
          : '<%= req.translations.disabled || "Disabled" %>';
      });
    }

    form.addEventListener('submit', async function(e) {
      e.preventDefault();

      const username = document.getElementById('username').value.trim();
      const discordId = document.getElementById('discordId').value.trim();
      const description = document.getElementById('description').value;

      if (!username || !discordId) {
        showToast('Username and Discord ID are required.', 'error');
        return;
      }

      if (!/^\d+$/.test(discordId)) {
        showToast('Discord ID must be a numeric string.', 'error');
        return;
      }

      const data = {
        username,
        discordId,
        description,
        isAdmin: isAdminToggle.checked,
      };

      const serverLimitEl = document.getElementById('serverLimit');
      data.serverLimit = serverLimitEl && serverLimitEl.value !== '' ? parseInt(serverLimitEl.value, 10) : null;

      const maxMemoryEl = document.getElementById('maxMemory');
      data.maxMemory = maxMemoryEl && maxMemoryEl.value !== '' ? parseInt(maxMemoryEl.value, 10) : null;

      const maxCpuEl = document.getElementById('maxCpu');
      data.maxCpu = maxCpuEl && maxCpuEl.value !== '' ? parseInt(maxCpuEl.value, 10) : null;

      const maxStorageEl = document.getElementById('maxStorage');
      data.maxStorage = maxStorageEl && maxStorageEl.value !== '' ? parseInt(maxStorageEl.value, 10) : null;

      const loader = showLoadingPopup('<%= req.translations.updatingUser || "Updating User" %>', '<%= req.translations.processingUserUpdate || "Processing user update..." %>');
      loader.updateProgress(20, '<%= req.translations.sendingUserInformation || "Sending user information..." %>');

      try {
        const response = await fetch('/admin/users/update/<%= dataUser.id %>/', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(data),
        });

        const responseData = await response.json();

        if (responseData.error) {
          loader.close();
          showToast(responseData.error, 'error');
        } else {
          loader.updateProgress(100, '<%= req.translations.userUpdatedSuccessfully || "User updated successfully!" %>');
          setTimeout(() => {
            loader.close();
            showToast(responseData.message || '<%= req.translations.userUpdatedSuccessfully || "User updated successfully" %>', 'success');
            setTimeout(() => {
              window.location.href = '/admin/users';
            }, 1000);
          }, 500);
        }
      } catch (error) {
        loader.close();
        console.error('Error:', error);
        showToast('<%= req.translations.errorUpdatingUser || "Error updating user" %>', 'error');
      }
    });
  });
</script>

<%- include('../../components/footer') %>
