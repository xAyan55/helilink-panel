<%- include('../components/header', { title: 'Sign in' }) %>

<style>
  body { padding: 0 !important; }
  ::-webkit-scrollbar { display: none; }
  body, html { height: 100%; margin: 0; }

  .auth-split { position: relative; display: block; min-height: 100vh; }
  .auth-image {
    position: fixed;
    inset: 0;
    display: block;
    z-index: 0;
    background: url('<%= settings.loginWallpaper || "/assets/wallpapers/login.jpeg" %>') center/cover no-repeat;
  }
  .auth-panel {
    position: relative;
    z-index: 1;
    max-width: 100%;
    border-right: none;
    padding: 40px 24px;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    justify-content: center;
    background: var(--theme-bg-card, rgba(255, 255, 255, 0.95));
  }
  html.dark .auth-panel {
    background: var(--theme-bg-card, rgba(20, 20, 20, 0.95));
  }

  .discord-submit {
    width: 100%; padding: 12px; border-radius: 10px;
    background: #5865F2; color: white !important; font-size: 14px; font-weight: 500;
    border: none; cursor: pointer; transition: background 0.15s;
    font-family: inherit; display: flex; align-items: center; justify-content: center; gap: 10px;
    text-decoration: none; box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1), 0 2px 4px -1px rgba(0, 0, 0, 0.06);
  }
  .discord-submit:hover { background: #4752C4; text-decoration: none; }
  .discord-submit:active { background: #3C45A3; }

  .auth-panel { opacity: 0; transform: translateY(12px); transition: opacity 0.4s ease, transform 0.4s cubic-bezier(0.16,1,0.3,1); }
  .auth-panel.visible { opacity: 1; transform: translateY(0); }
</style>

<div class="auth-split">
  <div class="auth-image"></div>
  <div class="auth-panel" id="authPanel">

    <div class="mb-8">
      <% if (settings.logo) { %>
      <img src="<%= settings.logo %>" alt="" class="h-10 w-10 rounded-xl object-contain mb-5">
      <% } %>
      <h1 class="text-2xl font-semibold text-neutral-900 dark:text-white">Sign in</h1>
      <p class="text-sm text-neutral-500 mt-1">to <%= settings.title %></p>
    </div>

    <% if (req.query.err) { %>
    <div class="rounded-xl bg-red-50 dark:bg-red-500/10 border border-red-200 dark:border-red-500/20 px-4 py-3 mb-5">
      <p class="text-sm font-medium text-red-700 dark:text-red-400">
        <% if (req.query.err === 'invalid_state') { %>Security check failed: invalid state.
        <% } else if (req.query.err === 'missing_code') { %>Authorization code missing from Discord callback.
        <% } else if (req.query.err === 'invalid_discord_user') { %>Failed to fetch user identity from Discord.
        <% } else if (req.query.err === 'oauth_failed') { %>Discord authentication failed. Please try again.
        <% } else if (req.query.err === 'oauth_init_failed') { %>Failed to start Discord login flow.
        <% } else { %>Something went wrong. Please try again.<% } %>
      </p>
    </div>
    <% } %>

    <div class="space-y-4">
      <a href="/auth/discord" class="discord-submit" id="submitBtn">
        <svg class="h-5 w-5 fill-current" viewBox="0 0 127.14 96.36" xmlns="http://www.w3.org/2000/svg">
          <path d="M107.7,8.07A105.15,105.15,0,0,0,77.26,0a77.19,77.19,0,0,0-3.3,6.83A96.67,96.67,0,0,0,53.22,6.83,77.19,77.19,0,0,0,49.88,0,105.15,105.15,0,0,0,19.44,8.07C3.66,31.58-1.86,54.65,1,77.53A105.73,105.73,0,0,0,32,96.36a77.7,77.7,0,0,0,6.63-10.85,68.43,68.43,0,0,1-10.5-5c1-.73,2-1.48,2.93-2.25a74.24,74.24,0,0,0,72.1,0c1,.77,2,1.52,2.93,2.25a68.43,68.43,0,0,1-10.5,5,77.7,77.7,0,0,0,6.63,10.85,105.73,105.73,0,0,0,31.59-18.83C129.24,54.65,123.72,31.58,107.7,8.07ZM42.45,65.69C36.18,65.69,31,60,31,53S36.18,40.36,42.45,40.36,53.83,46,53.83,53,48.72,65.69,42.45,65.69Zm42.24,0C78.41,65.69,73.24,60,73.24,53S78.41,40.36,84.69,40.36,96.07,46,96.07,53,91,65.69,84.69,65.69Z"/>
        </svg>
        <span>Continue with Discord</span>
      </a>
    </div>

  </div>
</div>

<script nonce="<%- nonce %>">
  requestAnimationFrame(function () {
    requestAnimationFrame(function () {
      document.getElementById('authPanel').classList.add('visible');
    });
  });

  document.getElementById('submitBtn').addEventListener('click', function () {
    this.style.opacity = '0.6';
    this.style.pointerEvents = 'none';
  });
</script>

<%- include('../components/footer') %>
