<%- include('../components/header', { title: req.translations.userAccountTitle || 'Account' }) %>

<main id="page-content" class="">
  <%- include('../components/template') %>
  <%- include('../components/toast') %>

  <div class="px-4 py-5 space-y-4">

    <div class="mb-2 flex items-start justify-between gap-3">
      <div>
        <h1 class="text-base font-medium text-neutral-800 dark:text-white"><%= req.translations.userAccountTitle || 'Account' %></h1>
        <p class="text-xs text-neutral-500 mt-0.5"><%= req.translations.userAccountText || 'View your profile and manage preferences.' %></p>
      </div>
      <a href="/credits"
        class="flex items-center gap-1.5 rounded-xl border border-neutral-200 dark:border-white/5 bg-white dark:bg-white/5 px-3 py-2 text-xs font-medium text-neutral-600 dark:text-neutral-400 shadow-sm dark:shadow-none transition shrink-0">
        <%- icon('circle-alert', { class: 'w-3.5 h-3.5' }) %>
        Credits
      </a>
    </div>

    <!-- Discord identity details (Read-only) -->
    <div class="rounded-2xl bg-neutral-50 dark:bg-neutral-800/20 border border-neutral-200 dark:border-white/5 p-4 space-y-4">
      <h2 class="text-xs font-semibold text-neutral-400 dark:text-neutral-500 uppercase tracking-wider">Discord Identity</h2>
      <div class="space-y-3">
        <div>
          <label class="block text-xs font-medium text-neutral-500 dark:text-neutral-400 mb-1">Discord Username</label>
          <input type="text" value="<%= user.discord_username || 'N/A' %>" readonly
            class="rounded-xl border border-neutral-200 dark:border-neutral-600/30 text-sm w-full bg-neutral-100 dark:bg-neutral-800/40 px-3 py-2.5 text-neutral-500 dark:text-neutral-400 cursor-not-allowed outline-none">
        </div>
        <div>
          <label class="block text-xs font-medium text-neutral-500 dark:text-neutral-400 mb-1">Display Name</label>
          <input type="text" value="<%= user.discord_display_name || 'N/A' %>" readonly
            class="rounded-xl border border-neutral-200 dark:border-neutral-600/30 text-sm w-full bg-neutral-100 dark:bg-neutral-800/40 px-3 py-2.5 text-neutral-500 dark:text-neutral-400 cursor-not-allowed outline-none">
        </div>
        <div>
          <label class="block text-xs font-medium text-neutral-500 dark:text-neutral-400 mb-1">Discord Email</label>
          <input type="text" value="<%= user.discord_email || 'N/A' %>" readonly
            class="rounded-xl border border-neutral-200 dark:border-neutral-600/30 text-sm w-full bg-neutral-100 dark:bg-neutral-800/40 px-3 py-2.5 text-neutral-500 dark:text-neutral-400 cursor-not-allowed outline-none">
        </div>
      </div>
    </div>

    <!-- Account Details (Editable) -->
    <div class="rounded-2xl bg-neutral-50 dark:bg-neutral-800/20 border border-neutral-200 dark:border-white/5 p-4">
      <form id="change-description-form" class="mb-4">
        <%- include('../components/csrf') %>
        <label class="flex items-center gap-1.5 text-xs font-medium text-neutral-600 dark:text-neutral-400 mb-1.5"><%- icon('file-text', { class: 'w-3 h-3' }) %> <%= req.translations.description || 'Description' %></label>
        <textarea id="description" name="description" rows="3"
          class="rounded-xl border border-neutral-200 dark:border-neutral-600/30 focus:outline-none text-sm w-full px-3 py-2 bg-neutral-100 dark:bg-neutral-700/20 placeholder-neutral-400 text-neutral-800 dark:text-white resize-none transition"
          placeholder="<%= user.description %>"><%= user.description %></textarea>
        <button type="submit" class="mt-2 rounded-xl bg-neutral-900 dark:bg-white text-white dark:text-neutral-900 px-3 py-2 text-sm font-medium transition">
          Save
        </button>
      </form>
    </div>

    <!-- Language -->
    <div class="rounded-2xl bg-neutral-50 dark:bg-neutral-800/20 border border-neutral-200 dark:border-white/5 p-4">
      <p class="text-sm font-medium text-neutral-800 dark:text-white mb-3"><%- icon('globe', { class: 'w-3.5 h-3.5 inline mr-1' }) %><%= req.translations.languagePreference || 'Language' %></p>
      <form id="language-preference-form">
        <%- include('../components/csrf') %>
        <select id="language" name="language"
          class="rounded-xl border border-neutral-200 dark:border-neutral-600/30 focus:outline-none text-sm w-full px-3 py-2.5 bg-neutral-100 dark:bg-neutral-700/20 text-neutral-800 dark:text-white mb-3 transition">
          <option value="en"  <%= req.lang === 'en'  ? 'selected' : '' %>>English</option>
          <option value="fr"  <%= req.lang === 'fr'  ? 'selected' : '' %>>Français</option>
          <option value="de"  <%= req.lang === 'de'  ? 'selected' : '' %>>Deutsch</option>
          <option value="es"  <%= req.lang === 'es'  ? 'selected' : '' %>>Español</option>
          <option value="pt"  <%= req.lang === 'pt'  ? 'selected' : '' %>>Português</option>
          <option value="it"  <%= req.lang === 'it'  ? 'selected' : '' %>>Italiano</option>
          <option value="ru"  <%= req.lang === 'ru'  ? 'selected' : '' %>>Русский</option>
          <option value="zh"  <%= req.lang === 'zh'  ? 'selected' : '' %>>中文</option>
          <option value="ja"  <%= req.lang === 'ja'  ? 'selected' : '' %>>日本語</option>
          <option value="ta"  <%= req.lang === 'ta'  ? 'selected' : '' %>>தமிழ்</option>
        </select>
        <button type="submit" class="rounded-xl bg-neutral-900 dark:bg-white text-white dark:text-neutral-900 px-3 py-2 text-sm font-medium transition">
          <%= req.translations.saveLanguagePreference || 'Save' %>
        </button>
      </form>
    </div>

    <!-- 2FA (Legacy Placeholder) -->
    <div class="rounded-2xl bg-neutral-50 dark:bg-neutral-800/20 border border-neutral-200 dark:border-white/5 p-4">
      <p class="flex items-center gap-1.5 text-xs font-medium text-neutral-500 dark:text-neutral-400 mb-1"><%- icon('shield', { class: 'w-3 h-3' }) %> <%= req.translations.twoFactorAuth || 'Two-factor authentication' %></p>
      <p class="text-xs text-neutral-500 dark:text-neutral-400 mt-2">Managed securely via Discord Authentication.</p>
    </div>

    <!-- Login history -->
    <div class="rounded-2xl bg-neutral-50 dark:bg-neutral-800/20 border border-neutral-200 dark:border-white/5 p-4">
      <p class="text-sm font-medium text-neutral-800 dark:text-white mb-3"><%= req.translations.loginHistory || 'Login history' %></p>
      <div class="space-y-2">
        <% if (loginHistory && loginHistory.length > 0) { %>
          <% loginHistory.forEach(login => { %>
          <div class="rounded-xl bg-neutral-100 dark:bg-neutral-700/20 border border-neutral-200 dark:border-white/5 px-3 py-2.5">
            <p class="text-xs font-medium text-neutral-700 dark:text-neutral-300"><%= new Date(login.timestamp).toLocaleString() %></p>
            <p class="text-[11px] text-neutral-500 font-mono mt-0.5"><%= login.ipAddress || 'Unknown IP' %></p>
            <p class="text-[11px] text-neutral-400 truncate mt-0.5"><%= login.userAgent || 'Unknown device' %></p>
          </div>
          <% }) %>
        <% } else { %>
        <p class="text-sm text-neutral-400 text-center py-4"><%= req.translations.noLoginHistory || 'No login history available' %></p>
        <% } %>
      </div>
    </div>

  </div>
</main>

<script nonce="<%- nonce %>">
document.addEventListener('DOMContentLoaded', () => {
  const { showToast } = createToastSystem();
  const csrfToken = document.querySelector('meta[name="csrf-token"]')?.getAttribute('content');
  let submitting = false;

  async function post(url, data) {
    if (submitting) return { ok: false, text: 'Please wait' };
    submitting = true;
    try {
      const res = await fetch(url, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', 'CSRF-Token': csrfToken },
        body: JSON.stringify(data),
      });
      return { ok: res.ok, text: await res.text() };
    } finally { submitting = false; }
  }

  document.getElementById('change-description-form')?.addEventListener('submit', async e => {
    e.preventDefault();
    const el = e.target.querySelector('#description');
    const { ok, text } = await post('/update-description', { description: el.value.trim() });
    if (ok) { showToast('Description updated.', 'success'); el.placeholder = el.value.trim(); } else showToast(text);
  });

  document.getElementById('language-preference-form')?.addEventListener('submit', async e => {
    e.preventDefault();
    const lang = e.target.querySelector('#language').value;
    const res = await fetch('/set-language', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json', 'CSRF-Token': csrfToken },
      body: JSON.stringify({ language: lang }),
    });
    if (res.ok) { showToast('Language saved.', 'success'); setTimeout(() => location.reload(), 1400); }
    else showToast('Something went wrong.', 'error');
  });
});
</script>

<%- include('../components/footer') %>
